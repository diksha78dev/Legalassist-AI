# Environment Variables for Production Deployment

# ==================== Application Configuration ====================
ENVIRONMENT=production
LOG_LEVEL=INFO
APP_ENV=production
DEBUG=false

# ==================== Database Configuration ====================
# Use external secret management (AWS Secrets Manager, Vault, etc.)
DATABASE_URL=postgresql://legal_user:${DB_PASSWORD}@postgres:5432/legalassist_db
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# ==================== Cache Configuration ====================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=${REDIS_PASSWORD}

# ==================== API Keys (Use Secret Management) ====================
OPENAI_API_KEY=${OPENAI_API_KEY}
TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}
SENDGRID_API_KEY=${SENDGRID_API_KEY}

# ==================== Observability Configuration ====================

# Prometheus
PROMETHEUS_METRICS_PORT=9090
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Jaeger Tracing
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
JAEGER_ENABLED=true

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PATTERN=legalassist-%{+yyyy.MM.dd}

# Slack Alerts
SLACK_WEBHOOK_CRITICAL=${SLACK_WEBHOOK_CRITICAL}
SLACK_WEBHOOK_WARNING=${SLACK_WEBHOOK_WARNING}

# ==================== Security Configuration ====================
# SSL/TLS
ENABLE_HTTPS=true
SSL_CERT_PATH=/etc/certs/tls.crt
SSL_KEY_PATH=/etc/certs/tls.key

# Session security
SESSION_TIMEOUT=1800
SESSION_SECURE_COOKIE=true
SESSION_HTTPONLY=true

# Rate limiting
RATE_LIMIT_PER_IP=100
RATE_LIMIT_PER_USER=1000
RATE_LIMIT_WINDOW=3600

# ==================== Performance Tuning ====================
MAX_CONCURRENT_LLM_CALLS=5
REQUEST_QUEUE_ENABLED=true
REQUEST_QUEUE_SIZE=1000

# Connection timeouts
API_TIMEOUT=30
DB_CONNECT_TIMEOUT=10
REDIS_TIMEOUT=5

# ==================== Monitoring & Health Checks ====================
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
READINESS_PROBE_ENABLED=true
LIVENESS_PROBE_ENABLED=true

# ==================== Notification Configuration ====================
NOTIFICATION_SERVICE_ENABLED=true
DEADLINE_REMINDER_HOURS=24
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=60

# ==================== Feature Flags ====================
ENABLE_PROFILING=false
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_METRICS_ENDPOINT=true
ENABLE_HEALTH_ENDPOINT=true

# ==================== Backup & Disaster Recovery ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily
BACKUP_RETENTION_DAYS=30

# ==================== Sentry Error Tracking (Optional) ====================
SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==================== Datadog Monitoring (Optional) ====================
DATADOG_API_KEY=${DATADOG_API_KEY}
DATADOG_ENABLED=false

# ==================== Custom Metrics ====================
BUSINESS_METRICS_ENABLED=true
COST_TRACKING_ENABLED=true
TOKEN_USAGE_TRACKING_ENABLED=true
