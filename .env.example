# ==============================================================================
# LegalEase AI - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit your actual .env file to version control!

# --- App Identity ---
APP_NAME="LegalEase AI"
# Options: development, staging, production
APP_ENV=development
DEBUG=True

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Model Settings (LLM) ---
# Your OpenRouter API Key (Get it from https://openrouter.ai/keys)
OPENROUTER_API_KEY="your_openrouter_key_here"
# Optional: Override the base URL if using a different provider/proxy
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# The model ID to use by default
DEFAULT_MODEL="meta-llama/llama-3.1-8b-instruct"

# LLM Hyperparameters (Optional overrides)
# SUMMARY_MAX_TOKENS=280
# REMEDIES_MAX_TOKENS=900
# LLM_TEMPERATURE=0.05
# LLM_TIMEOUT=60.0

# --- OCR Settings ---
# Set to True to enable OCR for image-only PDFs (Requires Tesseract installed)
OCR_ENABLED=False
OCR_LANGUAGES="eng+hin"
# OCR_DPI=300

# --- File Processing ---
# MAX_FILE_SIZE_MB=25
# WARN_FILE_SIZE_MB=10
# TEXT_COMPRESSION_LIMIT=6000

# --- Database Settings ---
# Default is a local SQLite database
DATABASE_URL="sqlite:///./legalassist.db"

# --- Authentication (JWT & OTP) ---
# A strong, unique secret key for JWT signing. 
# If left blank in development, one will be generated and saved to .jwt_secret
JWT_SECRET=""
# OTP_EXPIRY_MINUTES=10
# OTP_MAX_ATTEMPTS=3

# --- Notification Settings (SMS - Twilio) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# --- Notification Settings (Email - SendGrid) ---
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@legalassist.ai"
